{
  "name": "@emailed/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "echo 'API server runs via bun directly — not part of Vercel web deployment'",
    "start": "bun run dist/index.js",
    "test": "vitest run",
    "test:e2e": "vitest run tests/e2e/",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@emailed/ai-engine": "workspace:*",
    "@emailed/crypto": "workspace:*",
    "@emailed/db": "workspace:*",
    "@emailed/dns": "workspace:*",
    "@emailed/mta": "workspace:*",
    "@emailed/reputation": "workspace:*",
    "@emailed/shared": "workspace:*",
    "@hono/zod-validator": "^0.4.0",
    "bullmq": "^5.0.0",
    "drizzle-orm": "^0.36.0",
    "hono": "^4.6.0",
    "ioredis": "^5.4.0",
    "jose": "^6.2.2",
    "stripe": "^17.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
