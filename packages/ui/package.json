{
  "name": "@alecrae/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*/index.ts"
  },
  "scripts": {
    "build": "echo 'UI package exports source directly via transpilePackages — no build step needed'",
    "dev": "echo 'UI package exports source directly — no dev build needed'",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@react-three/fiber": "^9.5.0",
    "@react-three/drei": "^10.0.0",
    "three": "^0.170.0"
  },
  "peerDependenciesMeta": {
    "@react-three/fiber": { "optional": true },
    "@react-three/drei": { "optional": true },
    "three": { "optional": true }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@react-three/fiber": "^9.5.0",
    "@react-three/drei": "^10.0.0",
    "three": "^0.170.0",
    "@types/three": "^0.170.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
