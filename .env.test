# =============================================================================
# Emailed — Test Environment
# =============================================================================
# Safe defaults for running the test suite locally. No real credentials.
# =============================================================================

# -- App -------------------------------------------------------------------
NODE_ENV=test
WEB_URL=http://localhost:3000
API_URL=http://localhost:4000
ADMIN_URL=http://localhost:3001

# -- Database --------------------------------------------------------------
POSTGRES_URL=postgres://emailed:emailed@localhost:5432/emailed_test
REDIS_URL=redis://localhost:6379/1
CLICKHOUSE_URL=http://localhost:8123/emailed_test

# -- Storage ---------------------------------------------------------------
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=emailed-test
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# -- Search ----------------------------------------------------------------
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_KEY=test-master-key

# -- Auth ------------------------------------------------------------------
JWT_SECRET=test-jwt-secret-do-not-use-in-production-0123456789
SESSION_SECRET=test-session-secret-do-not-use-in-production-01
OAUTH_CLIENT_ID=test-client-id
OAUTH_CLIENT_SECRET=test-client-secret

# -- Email -----------------------------------------------------------------
SMTP_PORT=2525
SMTP_HOSTNAME=localhost
DKIM_SELECTOR=test
DKIM_PRIVATE_KEY_PATH=./test/fixtures/dkim-test.pem

# -- AI --------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-test-key-not-real
AI_MODEL_ID=claude-sonnet-4-20250514

# -- Monitoring ------------------------------------------------------------
OTEL_ENDPOINT=http://localhost:4318
GRAFANA_URL=http://localhost:3002

# -- Payment ---------------------------------------------------------------
STRIPE_SECRET_KEY=your_stripe_test_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
