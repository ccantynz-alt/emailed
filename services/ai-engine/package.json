{
  "name": "@emailed/ai-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Core AI/ML engine for the Emailed platform \u2014 spam detection, reputation scoring, content analysis, and intelligent email assistance",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
