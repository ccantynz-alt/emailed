{
  "name": "@emailed/ai-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Core AI/ML engine for the Emailed platform — spam detection, reputation scoring, content analysis, and intelligent email assistance",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./spam": {
      "types": "./dist/spam/classifier.d.ts",
      "import": "./dist/spam/classifier.js"
    },
    "./reputation": {
      "types": "./dist/reputation/scorer.d.ts",
      "import": "./dist/reputation/scorer.js"
    },
    "./content": {
      "types": "./dist/content/analyzer.d.ts",
      "import": "./dist/content/analyzer.js"
    },
    "./compose": {
      "types": "./dist/compose/assistant.d.ts",
      "import": "./dist/compose/assistant.js"
    },
    "./priority": {
      "types": "./dist/priority/ranker.d.ts",
      "import": "./dist/priority/ranker.js"
    },
    "./relationships": {
      "types": "./dist/relationships/graph.d.ts",
      "import": "./dist/relationships/graph.js"
    }
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "tsc --project tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@emailed/shared": "workspace:*",
    "@emailed/db": "workspace:*",
    "@anthropic-ai/sdk": "^0.30.0",
    "ioredis": "^5.4.0",
    "pino": "^9.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
