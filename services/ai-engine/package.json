    },
    "./embeddings/types": {
      "bun": "./src/embeddings/types.ts",
      "types": "./src/embeddings/types.ts",
      "import": "./dist/embeddings/types.js"
    },
    "./embeddings/local": {
      "bun": "./src/embeddings/local.ts",
      "types": "./src/embeddings/local.ts",
      "import": "./dist/embeddings/local.js"
    },
