  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "echo 'Service builds independently \u2014 not part of Vercel web deployment'",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@emailed/shared": "workspace:*",
    "@emailed/db": "workspace:*",
    "@anthropic-ai/sdk": "^0.30.0",
    "drizzle-orm": "^0.36.0",
    "ioredis": "^5.4.0",
    "playwright": "^1.47.0",
