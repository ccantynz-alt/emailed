{
  "name": "@emailed/ai-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Core AI/ML engine for the Emailed platform — spam detection, reputation scoring, content analysis, and intelligent email assistance",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./spam": {
      "bun": "./src/spam/classifier.ts",
      "types": "./src/spam/classifier.ts",
      "import": "./dist/spam/classifier.js"
    },
    "./reputation": {
      "bun": "./src/reputation/scorer.ts",
      "types": "./src/reputation/scorer.ts",
      "import": "./dist/reputation/scorer.js"
    },
    "./content": {
      "bun": "./src/content/analyzer.ts",
      "types": "./src/content/analyzer.ts",
      "import": "./dist/content/analyzer.js"
    },
    "./compose": {
      "bun": "./src/compose/assistant.ts",
      "types": "./src/compose/assistant.ts",
      "import": "./dist/compose/assistant.js"
    },
    "./priority": {
      "bun": "./src/priority/ranker.ts",
      "types": "./src/priority/ranker.ts",
      "import": "./dist/priority/ranker.js"
    },
    "./relationships": {
      "bun": "./src/relationships/graph.ts",
      "types": "./src/relationships/graph.ts",
      "import": "./dist/relationships/graph.js"
    },
    "./classifier": {
      "bun": "./src/classifier.ts",
      "types": "./src/classifier.ts",
      "import": "./dist/classifier.js"
    },
    "./embeddings/voyage": {
      "bun": "./src/embeddings/voyage.ts",
      "types": "./src/embeddings/voyage.ts",
      "import": "./dist/embeddings/voyage.js"
    },
    "./inbox": {
      "bun": "./src/inbox/smart-inbox.ts",
      "types": "./src/inbox/smart-inbox.ts",
      "import": "./dist/inbox/smart-inbox.js"
    },
    "./inbox/newsletter-summarizer": {
      "bun": "./src/inbox/newsletter-summarizer.ts",
      "types": "./src/inbox/newsletter-summarizer.ts",
      "import": "./dist/inbox/newsletter-summarizer.js"
    },
    "./inbox/email-explainer": {
      "bun": "./src/inbox/email-explainer.ts",
      "types": "./src/inbox/email-explainer.ts",
      "import": "./dist/inbox/email-explainer.js"
    },
    "./agent": {
      "bun": "./src/agent/index.ts",
      "types": "./src/agent/index.ts",
      "import": "./dist/agent/index.js"
    },
    "./unsubscribe": {
      "bun": "./src/unsubscribe/index.ts",
      "types": "./src/unsubscribe/index.ts",
      "import": "./dist/unsubscribe/index.js"
    }
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "tsc --project tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@emailed/shared": "workspace:*",
    "@emailed/db": "workspace:*",
    "@anthropic-ai/sdk": "^0.30.0",
    "ioredis": "^5.4.0",
    "playwright": "^1.47.0",
    "pino": "^9.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
