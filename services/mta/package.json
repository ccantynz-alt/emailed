{
  "name": "@emailed/mta",
  "version": "0.1.0",
  "private": true,
  "description": "Mail Transfer Agent - Custom SMTP server and outbound delivery engine",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./lib": {
      "types": "./src/lib.ts",
      "default": "./src/lib.ts"
    }
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "echo 'Service builds independently \u2014 not part of Vercel web deployment'",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@emailed/shared": "workspace:*",
    "@emailed/db": "workspace:*",
    "@emailed/crypto": "workspace:*",
    "@emailed/email-parser": "workspace:*",
    "bullmq": "^5.0.0",
    "ioredis": "^5.4.0",
    "drizzle-orm": "^0.36.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
