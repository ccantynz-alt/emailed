{
  "name": "@alecrae/collab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/server.ts",
  "types": "src/server.ts",
  "scripts": {
    "dev": "bun run --hot src/server.ts",
    "build": "echo 'Service builds independently \u2014 not part of Vercel web deployment'",
