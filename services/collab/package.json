    "jose": "^5.9.0",
    "yjs": "^13.6.0",
    "y-protocols": "^1.0.6",
    "y-websocket": "^2.0.4",
    "lib0": "^0.2.94"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
