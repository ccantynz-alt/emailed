{
  "compilerOptions": {
    "target": "ES2024",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2024"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "paths": {
      "@alecrae/shared": ["./packages/shared/src/index.ts"],
      "@alecrae/db": ["./packages/db/src/index.ts"],
      "@alecrae/ui": ["./packages/ui/src/index.ts"],
      "@alecrae/crypto": ["./packages/crypto/src/index.ts"],
      "@alecrae/sdk": ["./packages/sdk/src/index.ts"],
      "@alecrae/email-parser": ["./packages/email-parser/src/index.ts"],
      "@alecrae/dns": ["./services/dns/src/index.ts"],
      "@alecrae/security": ["./services/security/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", ".next", "coverage"]
}
