{
  "name": "emailed",
  "version": "0.1.0",
  "private": true,
  "description": "AI-Native Email Infrastructure Platform",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*",
    "infrastructure/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:migrate": "bun run --cwd packages/db db:migrate",
    "db:seed": "bun run scripts/seed.ts",
    "db:studio": "bun run --cwd packages/db drizzle-kit studio"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "bun-types": "^1.3.11",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "bun@1.2.0"
}
