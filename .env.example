# =============================================================================
# Emailed — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Never commit the .env file to version control.
# =============================================================================

# -- App -------------------------------------------------------------------
NODE_ENV=development                      # development | staging | production
WEB_URL=http://localhost:3000             # Public URL of the web app
API_URL=http://localhost:4000             # Public URL of the API
ADMIN_URL=http://localhost:3001           # Public URL of the admin dashboard

# -- Database --------------------------------------------------------------
POSTGRES_URL=                             # PostgreSQL connection string (e.g. postgres://user:pass@localhost:5432/emailed)
REDIS_URL=                                # Redis connection string (e.g. redis://localhost:6379)
CLICKHOUSE_URL=                           # ClickHouse connection string (e.g. http://localhost:8123)

# -- Storage ---------------------------------------------------------------
S3_ENDPOINT=                              # S3-compatible endpoint (e.g. http://localhost:9000 for MinIO)
S3_BUCKET=                                # Bucket name for attachments and archival
S3_ACCESS_KEY=                            # S3 access key ID
S3_SECRET_KEY=                            # S3 secret access key

# -- Search ----------------------------------------------------------------
MEILISEARCH_URL=                          # Meilisearch URL (e.g. http://localhost:7700)
MEILISEARCH_KEY=                          # Meilisearch API key

# -- Auth ------------------------------------------------------------------
JWT_SECRET=                               # Secret key for signing JWTs (min 32 characters)
SESSION_SECRET=                           # Secret key for session encryption (min 32 characters)
OAUTH_CLIENT_ID=                          # OAuth2/OIDC client ID
OAUTH_CLIENT_SECRET=                      # OAuth2/OIDC client secret

# -- Email -----------------------------------------------------------------
SMTP_PORT=25                              # SMTP listener port
SMTP_HOSTNAME=                            # Public SMTP hostname (e.g. mail.emailed.dev)
DKIM_SELECTOR=                            # DKIM selector (e.g. default)
DKIM_PRIVATE_KEY_PATH=                    # Absolute path to DKIM private key file

# -- AI --------------------------------------------------------------------
ANTHROPIC_API_KEY=                        # Anthropic API key for Claude
AI_MODEL_ID=                              # Model identifier (e.g. claude-sonnet-4-20250514)

# -- Monitoring ------------------------------------------------------------
OTEL_ENDPOINT=                            # OpenTelemetry collector endpoint (e.g. http://localhost:4318)
GRAFANA_URL=                              # Grafana dashboard URL (e.g. http://localhost:3002)

# -- Payment ---------------------------------------------------------------
STRIPE_SECRET_KEY=                        # Stripe secret key (sk_test_... or sk_live_...)
STRIPE_WEBHOOK_SECRET=                    # Stripe webhook signing secret (whsec_...)
