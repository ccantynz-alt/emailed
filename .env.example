# =============================================================================
# Emailed — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Never commit the .env file to version control.
# =============================================================================

# -- App -------------------------------------------------------------------
NODE_ENV=development                      # development | staging | production
PORT=3001                                # API server port

# -- Database --------------------------------------------------------------
DATABASE_URL=postgres://emailed:dev_password@localhost:5432/emailed
REDIS_URL=redis://localhost:6379

# -- ClickHouse (Analytics) ------------------------------------------------
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=emailed
CLICKHOUSE_PASSWORD=dev_password

# -- Storage (S3 / MinIO) -------------------------------------------------
S3_ENDPOINT=http://localhost:9002         # MinIO S3 API port
S3_ACCESS_KEY=emailed
S3_SECRET_KEY=dev_password
S3_BUCKET=emailed-attachments

# -- Search (Meilisearch) -------------------------------------------------
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=dev_master_key

# -- Web App ---------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001  # API URL for the web frontend

# -- Auth ------------------------------------------------------------------
JWT_SECRET=change_me_in_production        # Min 32 characters in production
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# -- MTA (Mail Transfer Agent) --------------------------------------------
MTA_HOSTNAME=mail.emailed.dev            # Public SMTP hostname
MTA_QUEUE_NAME=emailed:outbound
MTA_WORKER_CONCURRENCY=10
DKIM_SELECTOR=default

# -- Relay (outbound email delivery) ---------------------------------------
# Set RELAY_PROVIDER to route outbound email through a managed relay
# instead of direct MX delivery. Options: ses | mailchannels | smtp
# RELAY_PROVIDER=ses

# Amazon SES SMTP relay
# SES_SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SES_SMTP_PORT=587
# SES_SMTP_USERNAME=                       # SES SMTP credential username
# SES_SMTP_PASSWORD=                       # SES SMTP credential password
# SES_REGION=us-east-1

# MailChannels HTTP API
# MAILCHANNELS_API_KEY=                    # MailChannels API key
# MAILCHANNELS_ENDPOINT=                   # Optional endpoint override

# Generic SMTP relay
# SMTP_RELAY_HOST=                         # Relay hostname
# SMTP_RELAY_PORT=587                      # Relay port (587 or 465)
# SMTP_RELAY_USERNAME=                     # Optional auth username
# SMTP_RELAY_PASSWORD=                     # Optional auth password
# SMTP_RELAY_TLS=true                      # Use TLS (default true)

# -- AI (optional) ---------------------------------------------------------
# ANTHROPIC_API_KEY=                      # Anthropic API key for Claude
# AI_MODEL_ID=claude-sonnet-4-20250514

# -- Monitoring (optional) ------------------------------------------------
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# GRAFANA_URL=http://localhost:3002

# -- Payment (optional) ---------------------------------------------------
# STRIPE_SECRET_KEY=                      # sk_test_... or sk_live_...
# STRIPE_WEBHOOK_SECRET=                  # whsec_...

# -- Docker Compose --------------------------------------------------------
POSTGRES_PASSWORD=dev_password
MINIO_ROOT_USER=emailed
MINIO_ROOT_PASSWORD=dev_password
