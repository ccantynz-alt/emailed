# ============================================================
# AlecRae - Production Environment Template
# ============================================================
# Never commit real values. Copy to .env.production, fill in,
# then push to Vercel/Fly/Cloudflare via their secret
# management. See env-audit.md in this directory for details
# on every variable, including where to obtain each value.
#
# Legend:
#   <angle_brackets>  = Craig-filled value
#   # OPTIONAL        = app runs without it (feature disabled)
#   # REQUIRED        = boot fails without it
# ============================================================


# ------------------------------------------------------------
# Core Runtime
# ------------------------------------------------------------
NODE_ENV=production
LOG_LEVEL=info
PORT=3000


# ------------------------------------------------------------
# Database - Neon Postgres
# ------------------------------------------------------------
# REQUIRED
DATABASE_URL=<neon_pooled_connection_string>
DIRECT_URL=<neon_direct_connection_string>


# ------------------------------------------------------------
# Cache / Queue - Upstash Redis
# ------------------------------------------------------------
# REQUIRED
UPSTASH_REDIS_REST_URL=<upstash_rest_url>
UPSTASH_REDIS_REST_TOKEN=<upstash_rest_token>


# ------------------------------------------------------------
# Auth - JWT + Sessions
# ------------------------------------------------------------
# REQUIRED - generate with: openssl rand -base64 64
JWT_SECRET=<random_64_byte_base64>
SESSION_SECRET=<random_64_byte_base64>

# RSA keypair for asymmetric JWT signing (multi-line PEM)
JWT_PUBLIC_KEY=<pem_public_key>
JWT_PRIVATE_KEY=<pem_private_key>

# OPTIONAL - defaults shown
JWT_ISSUER=alecrae
JWT_AUDIENCE=alecrae-collab


# ------------------------------------------------------------
# Auth - WebAuthn / Passkeys
# ------------------------------------------------------------
WEBAUTHN_RP_ID=alecrae.com
WEBAUTHN_RP_NAME=AlecRae
WEBAUTHN_ORIGIN=https://mail.alecrae.com


# ------------------------------------------------------------
# App URLs (public - safe to ship to browser)
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://mail.alecrae.com
NEXT_PUBLIC_API_URL=https://api.alecrae.com
NEXT_PUBLIC_WS_URL=wss://api.alecrae.com
NEXT_PUBLIC_MARKETING_URL=https://alecrae.com


# ------------------------------------------------------------
# AI - Anthropic Claude
# ------------------------------------------------------------
# REQUIRED for AI features (core product)
ANTHROPIC_API_KEY=<sk-ant-api03-xxxxx>


# ------------------------------------------------------------
# AI - OpenAI (Whisper transcription only)
# ------------------------------------------------------------
OPENAI_API_KEY=<sk-proj-xxxxx>


# ------------------------------------------------------------
# AI - Voyage (embeddings, semantic search)
# ------------------------------------------------------------
# OPTIONAL - disables semantic search if absent
VOYAGE_API_KEY=<pa-xxxxx>


# ------------------------------------------------------------
# Payments - Stripe
# ------------------------------------------------------------
STRIPE_SECRET_KEY=<sk_live_xxxxx>
STRIPE_WEBHOOK_SECRET=<whsec_xxxxx>
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=<pk_live_xxxxx>


# ------------------------------------------------------------
# OAuth - Google (Gmail sync + SSO)
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=<xxxxx.apps.googleusercontent.com>
GOOGLE_CLIENT_SECRET=<GOCSPX-xxxxx>


# ------------------------------------------------------------
# OAuth - Microsoft (Outlook / Graph API)
# ------------------------------------------------------------
MICROSOFT_CLIENT_ID=<azure_app_client_id>
MICROSOFT_CLIENT_SECRET=<azure_app_client_secret>
MICROSOFT_TENANT_ID=common


# ------------------------------------------------------------
# MTA - Outbound SMTP + DKIM signing
# ------------------------------------------------------------
MTA_HOSTNAME=mx1.alecrae.com
DKIM_SELECTOR=default

# Multi-line PEM - use: fly secrets set DKIM_PRIVATE_KEY="$(cat dkim.private)"
DKIM_PRIVATE_KEY=<pem_private_key>

POSTMASTER_EMAIL=postmaster@alecrae.com
ABUSE_EMAIL=abuse@alecrae.com
DMARC_EMAIL=dmarc@alecrae.com


# ------------------------------------------------------------
# Search - Meilisearch
# ------------------------------------------------------------
MEILI_HOST=<https://search.alecrae.com>
MEILI_MASTER_KEY=<meili_master_key>


# ------------------------------------------------------------
# Storage - Cloudflare R2
# ------------------------------------------------------------
R2_ACCESS_KEY_ID=<r2_access_key_id>
R2_SECRET_ACCESS_KEY=<r2_secret_access_key>
R2_BUCKET=alecrae-attachments
R2_ENDPOINT=<https://account-id.r2.cloudflarestorage.com>


# ------------------------------------------------------------
# Observability - OpenTelemetry
# ------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=<otlp_collector_url>
OTEL_SERVICE_NAME=alecrae-api


# ------------------------------------------------------------
# Observability - Sentry
# ------------------------------------------------------------
# OPTIONAL - disables error reporting if absent
SENTRY_DSN=<https://key@sentry.io/project>


# ------------------------------------------------------------
# Collab (Yjs real-time drafting) - S2 feature
# ------------------------------------------------------------
# OPTIONAL - defaults shown in env-audit.md
COLLAB_WS_URL=wss://collab.alecrae.com
COLLAB_HTTP_URL=https://collab.alecrae.com
COLLAB_JWT_SECRET=<random_64_byte_base64_or_reuse_JWT_SECRET>


# ------------------------------------------------------------
# Enterprise - SAML SSO (Team/Enterprise plans only)
# ------------------------------------------------------------
# OPTIONAL - disables SAML login if absent
SAML_ENTITY_ID=https://admin.alecrae.com/saml/metadata
SAML_ACS_URL=https://admin.alecrae.com/saml/acs

# Multi-line PEM
SAML_CERT=<pem_x509_cert>
SAML_PRIVATE_KEY=<pem_private_key>
