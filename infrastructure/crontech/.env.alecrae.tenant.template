# =============================================================================
# AlecRae on Crontech — Tenant .env Template
# =============================================================================
# Paste this file into the Crontech onboarding wizard at:
#   https://crontech.ai/admin/onboard
#
# The wizard runs ENTIRELY client-side. Values never leave the browser.
# It will:
#   1. Auto-map known keys (DATABASE_URL → TURSO_DATABASE_URL, etc.)
#   2. Flag missing required Crontech vars
#   3. Output: .env.crontech + crontech-migration-checklist.md
#
# IMPORTANT — AlecRae-specific overrides AFTER the wizard:
#   - AlecRae uses Neon Postgres (Drizzle ORM, Postgres-flavored schema).
#     The wizard will suggest mapping DATABASE_URL → TURSO_DATABASE_URL.
#     KEEP DATABASE_URL pointing at Neon. Crontech runtime supports both.
#     Discard or ignore the TURSO_* mapping for the AlecRae tenant.
#   - The MTA (services/mta) needs port 25 + persistent disk + DKIM key on
#     bare-metal — confirm Crontech's deploy-agent supports long-lived
#     processes with raw TCP, or keep MTA on its existing Fly.io microVM.
#
# Replace every <angle_bracket> placeholder before pasting. Generate secrets
# with: openssl rand -base64 64
# =============================================================================


# -----------------------------------------------------------------------------
# Core Runtime
# -----------------------------------------------------------------------------
NODE_ENV=production
LOG_LEVEL=info
PORT=3000


# -----------------------------------------------------------------------------
# Database — Neon Postgres (NOT Turso — see header note)
# -----------------------------------------------------------------------------
DATABASE_URL=<neon_pooled_connection_string>
DIRECT_URL=<neon_direct_connection_string>


# -----------------------------------------------------------------------------
# Cache / Queue — Upstash Redis
# -----------------------------------------------------------------------------
REDIS_URL=<upstash_redis_url>
UPSTASH_REDIS_REST_URL=<upstash_rest_url>
UPSTASH_REDIS_REST_TOKEN=<upstash_rest_token>


# -----------------------------------------------------------------------------
# Auth — JWT + Sessions
# Wizard will auto-map: AUTH_SECRET → SESSION_SECRET (we set both for safety).
# Generate each with: openssl rand -base64 64
# -----------------------------------------------------------------------------
JWT_SECRET=<random_64_byte_base64>
SESSION_SECRET=<random_64_byte_base64>
JWT_ISSUER=alecrae
JWT_AUDIENCE=alecrae-collab

# RSA keypair for asymmetric JWT signing (multi-line PEM)
JWT_PUBLIC_KEY=<pem_public_key>
JWT_PRIVATE_KEY=<pem_private_key>


# -----------------------------------------------------------------------------
# Auth — WebAuthn / Passkeys
# -----------------------------------------------------------------------------
WEBAUTHN_RP_ID=alecrae.com
WEBAUTHN_RP_NAME=AlecRae
WEBAUTHN_ORIGIN=https://mail.alecrae.com


# -----------------------------------------------------------------------------
# Crontech-required (wizard will flag if missing)
# -----------------------------------------------------------------------------
DEPLOY_AGENT_SECRET=<random_64_byte_base64>


# -----------------------------------------------------------------------------
# App URLs
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://mail.alecrae.com
NEXT_PUBLIC_API_URL=https://api.alecrae.com
NEXT_PUBLIC_WS_URL=wss://api.alecrae.com
NEXT_PUBLIC_MARKETING_URL=https://alecrae.com
ALECRAE_APP_URL=https://mail.alecrae.com


# -----------------------------------------------------------------------------
# AI — Anthropic Claude (REQUIRED — core product)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=<sk-ant-api03-xxxxx>


# -----------------------------------------------------------------------------
# AI — OpenAI (Whisper transcription)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=<sk-proj-xxxxx>


# -----------------------------------------------------------------------------
# AI — Voyage (embeddings, semantic search)
# OPTIONAL — disables semantic search if absent
# -----------------------------------------------------------------------------
VOYAGE_API_KEY=<pa-xxxxx>


# -----------------------------------------------------------------------------
# Payments — Stripe
# Wizard will auto-map: NEXT_PUBLIC_STRIPE_KEY / STRIPE_PUBLIC_KEY →
#                       STRIPE_PUBLISHABLE_KEY
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=<sk_live_xxxxx>
STRIPE_WEBHOOK_SECRET=<whsec_xxxxx>
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=<pk_live_xxxxx>
STRIPE_PRICE_STARTER=<price_id_personal_9>
STRIPE_PRICE_PROFESSIONAL=<price_id_pro_19>
STRIPE_PRICE_ENTERPRISE=<price_id_enterprise>


# -----------------------------------------------------------------------------
# OAuth — Google (Gmail sync + SSO)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=<xxxxx.apps.googleusercontent.com>
GOOGLE_CLIENT_SECRET=<GOCSPX-xxxxx>
GOOGLE_REDIRECT_URI=https://api.alecrae.com/auth/google/callback


# -----------------------------------------------------------------------------
# OAuth — Microsoft (Outlook / Graph API)
# -----------------------------------------------------------------------------
MICROSOFT_CLIENT_ID=<azure_app_client_id>
MICROSOFT_CLIENT_SECRET=<azure_app_client_secret>
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=https://api.alecrae.com/auth/microsoft/callback


# -----------------------------------------------------------------------------
# MTA — Outbound SMTP + DKIM signing
# NOTE: needs raw TCP port 25 + persistent disk. If Crontech deploy-agent
# does not support that, leave MTA on Fly.io and only deploy api/web/admin
# to Crontech.
# -----------------------------------------------------------------------------
MTA_HOSTNAME=mx1.alecrae.com
MTA_QUEUE_NAME=alecrae:outbound
MTA_WORKER_CONCURRENCY=10
DKIM_SELECTOR=default
DKIM_PRIVATE_KEY=<pem_private_key>

POSTMASTER_EMAIL=postmaster@alecrae.com
ABUSE_EMAIL=abuse@alecrae.com
DMARC_EMAIL=dmarc@alecrae.com

# Optional outbound relay (instead of direct MX delivery)
# RELAY_PROVIDER=ses
# SES_SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SES_SMTP_PORT=587
# SES_SMTP_USERNAME=<ses_username>
# SES_SMTP_PASSWORD=<ses_password>
# SES_REGION=us-east-1


# -----------------------------------------------------------------------------
# Search — Meilisearch
# -----------------------------------------------------------------------------
MEILI_URL=https://search.alecrae.com
MEILI_MASTER_KEY=<meili_master_key>
MEILISEARCH_URL=https://search.alecrae.com
MEILISEARCH_API_KEY=<meili_master_key>


# -----------------------------------------------------------------------------
# Storage — Cloudflare R2
# -----------------------------------------------------------------------------
R2_ACCESS_KEY_ID=<r2_access_key_id>
R2_SECRET_ACCESS_KEY=<r2_secret_access_key>
R2_BUCKET=alecrae-attachments
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com


# -----------------------------------------------------------------------------
# Collab (Yjs real-time drafting — S2 feature)
# -----------------------------------------------------------------------------
COLLAB_WS_URL=wss://collab.alecrae.com
COLLAB_HTTP_URL=https://collab.alecrae.com
COLLAB_JWT_SECRET=<random_64_byte_base64_or_reuse_JWT_SECRET>


# -----------------------------------------------------------------------------
# Webhooks
# -----------------------------------------------------------------------------
WEBHOOK_SECRET=<random_32_byte_hex>
INBOUND_WEBHOOK_SECRET=<random_32_byte_hex>
TRACKING_BASE_URL=https://track.alecrae.com


# -----------------------------------------------------------------------------
# Enterprise — SAML SSO (Team/Enterprise plans only)
# OPTIONAL — disables SAML login if absent
# -----------------------------------------------------------------------------
SAML_ENTITY_ID=https://admin.alecrae.com/saml/metadata
SAML_ACS_URL=https://admin.alecrae.com/saml/acs
SAML_CERT=<pem_x509_cert>
SAML_PRIVATE_KEY=<pem_private_key>


# -----------------------------------------------------------------------------
# Observability — OpenTelemetry
# -----------------------------------------------------------------------------
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=<otlp_collector_url>
OTEL_SERVICE_NAME=alecrae-api


# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ORIGINS=https://alecrae.com,https://mail.alecrae.com,https://admin.alecrae.com
