# ─── Dockerfile.web ──────────────────────────────────────────────────────────
# Next.js web application image for the AlecRae frontend.
# Extends the base image with Next.js standalone output optimization.
# ─────────────────────────────────────────────────────────────────────────────

ARG APP_NAME=web
ARG APP_PORT=3001

# Stage 1: Dependencies
FROM oven/bun:1.2-alpine AS deps

WORKDIR /app

COPY package.json bun.lockb ./
COPY packages/shared/package.json ./packages/shared/
COPY packages/ui/package.json ./packages/ui/
COPY apps/${APP_NAME}/package.json ./apps/${APP_NAME}/

RUN bun install --frozen-lockfile

# Stage 2: Build
FROM oven/bun:1.2-alpine AS builder

WORKDIR /app

ARG APP_NAME=web

COPY --from=deps /app/node_modules ./node_modules
COPY . .

# Build shared dependencies first
RUN bun run --filter @alecrae/shared build
RUN bun run --filter @alecrae/ui build
RUN bun run --filter @alecrae/${APP_NAME} build

# Stage 3: Production runtime
FROM oven/bun:1.2-alpine AS runner

WORKDIR /app

ARG APP_NAME=web
ARG APP_PORT=3001

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=${APP_PORT}

# Create non-root user
RUN addgroup --system --gid 1001 alecrae && \
    adduser --system --uid 1001 --ingroup alecrae web

# Copy Next.js standalone output
COPY --from=builder --chown=web:alecrae /app/apps/${APP_NAME}/.next/standalone ./
COPY --from=builder --chown=web:alecrae /app/apps/${APP_NAME}/.next/static ./apps/${APP_NAME}/.next/static
COPY --from=builder --chown=web:alecrae /app/apps/${APP_NAME}/public ./apps/${APP_NAME}/public

USER web

EXPOSE ${APP_PORT}

HEALTHCHECK --interval=10s --timeout=5s --start-period=30s --retries=3 \
    CMD ["sh", "-c", "wget --no-verbose --spider http://localhost:${PORT}/api/health || exit 1"]

CMD ["bun", "run", "server.js"]
